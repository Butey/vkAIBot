# VK Token (получить в https://vk.com/apps?act=manage)
VK_TOKEN=your_vk_token_here

# Google Gemini API Key (получить в https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# NVIDIA NIM API Key (получить в https://build.nvidia.com/models)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Модель по умолчанию (можно использовать любую из NVIDIA_MODELS или Gemini)
# Примеры: google/gemini-1.5-flash, meta/llama3-70b-instruct, mistralai/mistral-large
DEFAULT_MODEL=google/gemini-1.5-flash

# Пароль для доступа к веб-панели администратора
ADMIN_PASSWORD=your_secure_password_here

# Секретный ключ для сессий Flask (должен быть случайной строкой)
SECRET_KEY=your_random_secret_key_here
